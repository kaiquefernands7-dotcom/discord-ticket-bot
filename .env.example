# Token do seu Bot no Discord Developer Portal
DISCORD_TOKEN=INSIRA_SEU_TOKEN_AQUI

# ID da aplicação (Client ID) do seu Bot
CLIENT_ID=INSIRA_O_CLIENT_ID_AQUI

# ID do servidor do Discord onde o bot funcionará
GUILD_ID=INSIRA_O_ID_DO_SERVIDOR_AQUI

# ID do cargo de suporte que terá acesso aos tickets
SUPPORT_ROLE_ID=INSIRA_O_ID_DO_CARGO_DE_SUPORTE_AQUI

# ID da categoria onde os tickets serão criados
TICKET_CATEGORY_ID=INSIRA_O_ID_DA_CATEGORIA_DE_TICKETS_AQUI

# ID do cargo de "Mutado" para o comando /mutar
MUTED_ROLE_ID=INSIRA_O_ID_DO_CARGO_MUTADO_AQUI
